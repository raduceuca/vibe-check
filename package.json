{
  "name": "vibe-check-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:watch": "pnpm -r test:watch",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "clean": "pnpm -r exec rm -rf dist",
    "publish:all": "pnpm -r publish --no-git-checks",
    "publish:dry": "pnpm -r publish --no-git-checks --dry-run"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0"
  },
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=20.0.0"
  }
}
