{
  "name": "@wcgw/vibe-check-mcp",
  "version": "0.3.0",
  "type": "module",
  "description": "Project-isolated local hub and MCP bridge for VibeCheck browser issues",
  "main": "./dist/lib.cjs",
  "module": "./dist/lib.js",
  "types": "./dist/lib.d.ts",
  "bin": {
    "vibe-check-mcp": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/lib.d.ts",
        "default": "./dist/lib.js"
      },
      "require": {
        "types": "./dist/lib.d.cts",
        "default": "./dist/lib.cjs"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc -p tsconfig.lint.json",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@wcgw/vibe-check-protocol": "workspace:*"
  },
  "keywords": ["mcp", "performance", "monitoring", "ai-agent", "vibe-coding"],
  "author": "Radu Ceuca",
  "license": "MIT",
  "sideEffects": false,
  "homepage": "https://github.com/raduceuca/vibe-check#readme",
  "bugs": {
    "url": "https://github.com/raduceuca/vibe-check/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/raduceuca/vibe-check.git",
    "directory": "packages/mcp"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
