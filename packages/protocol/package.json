{
  "name": "@wcgw/vibe-check-protocol",
  "version": "0.2.0",
  "type": "module",
  "private": true,
  "description": "Shared wire-protocol types and enums for vibe-check (internal — bundled into the published packages, never shipped on its own)",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "sideEffects": false,
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  }
}
