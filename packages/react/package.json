{
  "name": "@wcgw/vibe-check",
  "version": "0.2.0",
  "type": "module",
  "description": "React performance monitoring overlay with AI/vibe-coding issue detection",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "size": "pnpm build && node scripts/size-check.mjs",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "dependencies": {
    "@wcgw/vibe-check-core": "workspace:^",
    "@phosphor-icons/react": "^2.1.7",
    "liveline": "^0.0.7"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@testing-library/jest-dom": "^6.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "jsdom": "^27.4.0"
  },
  "keywords": ["react", "performance", "monitoring", "web-vitals", "vibe-coding"],
  "author": "Radu Ceuca",
  "license": "MIT",
  "sideEffects": false,
  "homepage": "https://github.com/raduceuca/vibe-check#readme",
  "bugs": {
    "url": "https://github.com/raduceuca/vibe-check/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/raduceuca/vibe-check.git",
    "directory": "packages/react"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
